{:paths ["src"]
 ;; Depends on raster (the typed-dispatch compiler + numeric/array/linalg/par
 ;; substrate, incl. the raster.{knn,tausworthe,spatial} approximate-NN layer).
 ;; raster is on Clojars (Maven-resolvable since 0.2.x — TypedClojure is released,
 ;; so raster's POM declares it as a proper mvn dep).
 ;; For local development the :dev alias overrides this with a sibling checkout.
 :deps {org.replikativ/raster {:mvn/version "0.2.258"}}

 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :jvm-opts ["--enable-native-access=ALL-UNNAMED"
                    "--add-modules=jdk.incubator.vector"
                    "-Xss8m"
                    "-XX:ReservedCodeCacheSize=512m"]
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}

  ;; Run on the Valhalla JDK (raster's deftm kernels need --enable-preview etc.).
  ;; See raster's README for JDK setup. Mirrors raster's :valhalla jvm-opts
  ;; (minus the raster-internal "classes" AOT path).
  :valhalla {:jvm-opts ["-XX:ReservedCodeCacheSize=512m"
                        "-Xmx12g"
                        "--enable-preview"
                        "--add-exports" "java.base/jdk.internal.vm.annotation=ALL-UNNAMED"
                        "--add-exports" "java.base/jdk.internal.classfile.components=ALL-UNNAMED"
                        "--add-exports" "java.base/jdk.internal.classfile.impl=ALL-UNNAMED"
                        "--add-modules" "jdk.incubator.vector"]}

  ;; Local development: use a sibling raster checkout instead of the pinned sha.
  :dev {:extra-paths ["dev" "test"]
        :extra-deps {org.replikativ/raster {:local/root "../raster"}
                     criterium/criterium {:mvn/version "0.4.6"}}}

  :build {:deps {io.github.clojure/tools.build          {:mvn/version "0.10.6"}
                 slipset/deps-deploy                    {:mvn/version "0.2.2"}
                 io.github.borkdude/gh-release-artifact {:git/sha "b946558225a7839f6a0f644834e838e190dc2262"}
                 babashka/babashka.curl                 {:mvn/version "0.1.2"}
                 babashka/fs                            {:mvn/version "0.3.17"}
                 cheshire/cheshire                      {:mvn/version "5.11.0"}}
          :ns-default build}}}
